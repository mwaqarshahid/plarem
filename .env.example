# Copy this file to `.env` and paste your Google Maps Platform API key.
# Get one at https://console.cloud.google.com/apis/credentials
#
# Enable these APIs for the key:
# - Maps SDK for Android (native map tiles)
# - Maps SDK for iOS (if building for iOS)
# - Places API (address search)
# - Geocoding API (reverse geocoding tapped pins)
GOOGLE_MAPS_API_KEY=
